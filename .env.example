# =============================================================================
# TradeFlow AI — Environment Configuration
# Copy to .env and adjust values for local development.
# =============================================================================

# --- Application ----------------------------------------------------------------
NODE_ENV=development
APP_NAME=TradeFlow AI
APP_ENV=development

# --- Web (Next.js) ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_VERSION=v1

# --- API (FastAPI) --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true
API_SECRET_KEY=change-me-to-a-64-char-random-string-in-production-use-openssl-rand
API_CORS_ORIGINS=http://localhost:3000
API_LOG_LEVEL=INFO
API_LOG_FORMAT=json

# --- Database (PostgreSQL) ------------------------------------------------------
POSTGRES_USER=tradeflow
POSTGRES_PASSWORD=tradeflow_dev_password
POSTGRES_DB=tradeflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://tradeflow:tradeflow_dev_password@localhost:5432/tradeflow
DATABASE_URL_SYNC=postgresql+psycopg://tradeflow:tradeflow_dev_password@localhost:5432/tradeflow
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# --- Redis ---------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# --- Celery --------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# --- Authentication -----------------------------------------------------------
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
FRONTEND_URL=http://localhost:3000
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tradeflow.ai
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
AUTH_RATE_LIMIT_PER_MINUTE=20
AVATAR_UPLOAD_DIR=uploads/avatars
AVATAR_MAX_BYTES=2097152

# --- Stripe Billing (optional — dev mode when unset) ----------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS_DEFAULT=14
STRIPE_TAX_ENABLED=true

# --- Docker Compose overrides (used inside containers) --------------------------
# DATABASE_URL=postgresql+asyncpg://tradeflow:tradeflow_dev_password@postgres:5432/tradeflow
# REDIS_URL=redis://redis:6379/0
