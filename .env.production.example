# =============================================================================
# TradeFlow AI — Production Environment Template
# Copy to .env and fill ALL values before deploying.
# NEVER commit production secrets to version control.
# =============================================================================

APP_ENV=production
NODE_ENV=production
APP_NAME=TradeFlow AI
APP_VERSION=0.1.0

# --- Web -----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_VERSION=v1
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- API -----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_GRACEFUL_SHUTDOWN_SECONDS=30
API_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32_OR_LONGER
API_CORS_ORIGINS=https://app.example.com
API_TRUSTED_HOSTS=api.example.com,api
API_LOG_LEVEL=INFO
API_LOG_FORMAT=json
API_RATE_LIMIT_PER_MINUTE=300
API_ENABLE_GZIP=true

# --- Database ------------------------------------------------------------------
POSTGRES_USER=tradeflow
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=tradeflow
DATABASE_URL=postgresql+asyncpg://tradeflow:REPLACE@postgres:5432/tradeflow
DATABASE_URL_SYNC=postgresql+psycopg://tradeflow:REPLACE@postgres:5432/tradeflow
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# --- Redis ---------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Auth (production-hardened) ------------------------------------------------
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=tradeflow-api
JWT_AUDIENCE=tradeflow-web
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=.example.com
FRONTEND_URL=https://app.example.com
OAUTH_REDIRECT_BASE_URL=https://api.example.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
AUTH_RATE_LIMIT_PER_MINUTE=20

# --- Email ---------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tradeflow.ai

# --- Stripe --------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TAX_ENABLED=true

# --- Observability -------------------------------------------------------------
PROMETHEUS_ENABLED=true
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# --- Grafana (docker-compose.prod.yml) -----------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
