{
  "extends": "@tradeflow/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    },
    "incremental": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "playwright.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "e2e",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
