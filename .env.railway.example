# =============================================================================
# TradeFlow AI — Railway Environment Template
# Copy variables into Railway service dashboards (never commit secrets).
# See docs/deployment/ENVIRONMENT_VARIABLES.md for full reference.
# =============================================================================

# --- Shared / all API-derived services (api, worker, beat) -------------------
APP_ENV=production
APP_NAME=TradeFlow AI
APP_VERSION=0.1.0

# Railway Postgres plugin → reference as ${{Postgres.DATABASE_URL}}
# Config auto-converts postgresql:// → postgresql+asyncpg:// and psycopg://
DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL_SYNC=${{Postgres.DATABASE_URL}}
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Railway Redis plugin
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_MAX_CONNECTIONS=50
CELERY_BROKER_URL=${{Redis.REDIS_URL}}/1
CELERY_RESULT_BACKEND=${{Redis.REDIS_URL}}/2

# --- API service (tradeflow-api) ---------------------------------------------
# Railway sets PORT automatically — start.sh reads it; API_PORT is optional.
API_HOST=0.0.0.0
API_WORKERS=2
API_GRACEFUL_SHUTDOWN_SECONDS=30
API_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
API_CORS_ORIGINS=https://${{tradeflow-web.RAILWAY_PUBLIC_DOMAIN}}
API_TRUSTED_HOSTS=${{RAILWAY_PUBLIC_DOMAIN}},tradeflow-api.railway.internal
API_LOG_LEVEL=INFO
API_LOG_FORMAT=json
API_RATE_LIMIT_PER_MINUTE=300
API_ENABLE_GZIP=true
PROMETHEUS_ENABLED=true

# Migrations run via preDeployCommand in railway.toml (migrate.sh).
# Set true only if not using preDeployCommand:
# RUN_MIGRATIONS_ON_START=false

# --- Web service (tradeflow-web) — BUILD + RUNTIME ---------------------------
NODE_ENV=production
# RUNTIME (recommended): proxies /api/v1/* from the web app to the API service.
# Does not require a rebuild when changed — restart/redeploy web only.
API_PROXY_URL=https://${{tradeflow-api.RAILWAY_PUBLIC_DOMAIN}}
# BUILD-TIME (optional — used for SSR, docs links, OAuth display URLs):
NEXT_PUBLIC_APP_URL=https://${{tradeflow-web.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_API_URL=https://${{tradeflow-api.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_API_VERSION=v1

# --- Auth / JWT --------------------------------------------------------------
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=tradeflow-api
JWT_AUDIENCE=tradeflow-web
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
# Omit AUTH_COOKIE_DOMAIN for cross-subdomain Railway URLs; set for custom domain:
# AUTH_COOKIE_DOMAIN=.yourdomain.com
FRONTEND_URL=https://${{tradeflow-web.RAILWAY_PUBLIC_DOMAIN}}
OAUTH_REDIRECT_BASE_URL=https://${{tradeflow-api.RAILWAY_PUBLIC_DOMAIN}}

# --- OAuth (optional) --------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Email -------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tradeflow.ai

# --- Stripe ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TAX_ENABLED=true

# --- Celery worker (tradeflow-worker) ----------------------------------------
CELERY_CONCURRENCY=4
CELERY_LOG_LEVEL=INFO
CELERY_QUEUES=default,copy,risk,notifications,celery
# Free-tier Railway: run worker inside the API service instead of a new service.
# RUN_CELERY_WORKER=true
# RUN_CELERY_BEAT=true
# Or process tasks inline without a worker:
# CELERY_TASK_ALWAYS_EAGER=true

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# --- Broker APIs (per-user credentials stored encrypted in DB) ---------------
# Platform-level keys not required unless using shared webhook endpoints.

# --- Uploads (ephemeral on Railway — use S3 for production persistence) -------
AVATAR_UPLOAD_DIR=uploads/avatars
JOURNAL_UPLOAD_DIR=uploads/journal
